<!-- pages/profile_edit/profile_edit.wxml -->
<view class="container">
  <view class="hero-card">
    <view class="avatar-section" bindtap="onChooseAvatar">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{userInfo.avatar || '/images/default_avatar.png'}}" mode="aspectFill"></image>
        <view class="camera-icon">📷</view>
      </view>
      <text class="tip">点击更换头像</text>
    </view>

    <view class="hero-copy">
      <text class="hero-title">编辑个人资料</text>
      <text class="hero-subtitle">完善头像和昵称，让你的头条主页更有辨识度。</text>
    </view>
  </view>

  <view class="form-section section-card">
    <text class="card-title">基础信息</text>
    <view class="form-item">
      <text class="label">昵称</text>
      <input
        class="input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{userInfo.nickname}}"
        maxlength="20"
        bindchange="onNicknameChange"
      />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input disabled" value="{{maskedPhone || '未绑定'}}" disabled />
    </view>
  </view>

  <view class="action-section">
    <button class="save-btn" bindtap="onSaveProfile" loading="{{loading}}">保存修改</button>
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>
