/* pages/profile_edit/profile_edit.wxss */
.container {
  padding: 24rpx;
  background: linear-gradient(180deg, #fff2f2 0%, #f6f7fb 260rpx);
  min-height: 100vh;
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fff6f6 100%);
  border: 1rpx solid rgba(240, 65, 66, 0.12);
  box-shadow: var(--shadow-sm);
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrapper {
  padding: 0;
  width: 168rpx !important;
  height: 168rpx !important;
  border-radius: 50%;
  position: relative;
  background: none;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: var(--shadow-sm);
}

.camera-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: var(--color-brand);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.hero-copy {
  margin-top: 28rpx;
  text-align: center;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.form-section {
  padding: 30rpx;
  margin-bottom: 32rpx;
}

.card-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.input {
  flex: 1;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fbfcfe;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.input.disabled {
  color: var(--color-text-tertiary);
}

.action-section button {
  width: 100% !important;
  height: 92rpx;
  margin-bottom: 24rpx;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #f04142 82%) !important;
  color: #ffffff !important;
  box-shadow: var(--shadow-brand);
}

.logout-btn {
  background: #ffffff !important;
  color: var(--color-brand) !important;
  border: 1rpx solid rgba(240, 65, 66, 0.22);
}
