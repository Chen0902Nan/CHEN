/* 新闻详情页样式 */
.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 168rpx;
  background: var(--color-bg);
}

.hero-card,
.cover-card,
.news-content,
.action-bar,
.author-action-bar,
.comment-section {
  margin-bottom: 20rpx;
}

.hero-card {
  padding: 32rpx;
}

.news-title {
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1.45;
  font-weight: 700;
  color: var(--color-text-primary);
}

.author-info {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-soft);
}

.author-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: #eef1f6;
}

.author-meta {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.author-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.publish-time {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.follow-btn {
  min-width: 132rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  background: var(--color-brand);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx rgba(240, 65, 66, 0.18);
}

.follow-btn.following {
  background: #ffffff;
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
  box-shadow: none;
}

.news-stats {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.cover-card {
  overflow: hidden;
  padding: 0;
}

.news-image {
  width: 100%;
  display: block;
}

.news-content {
  padding: 32rpx;
}

.content-head {
  margin-bottom: 20rpx;
}

.content-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.content-tip {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.content-html {
  font-size: 31rpx;
  color: var(--color-text-primary);
  line-height: 1.9;
  word-break: break-word;
}

.content-html img,
.content-html image {
  max-width: 100% !important;
  height: auto !important;
  display: block;
  margin: 24rpx 0;
  border-radius: 20rpx;
}

.content-html p {
  margin: 24rpx 0;
}

.content-html h1,
.content-html h2,
.content-html h3,
.content-html h4,
.content-html h5,
.content-html h6 {
  margin: 36rpx 0 20rpx;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.content-html ul,
.content-html ol {
  margin: 20rpx 0;
  padding-left: 38rpx;
}

.content-html li {
  margin: 10rpx 0;
}

.content-html blockquote {
  margin: 28rpx 0;
  padding: 24rpx;
  border-left: 8rpx solid var(--color-brand);
  border-radius: 20rpx;
  background: var(--color-brand-soft);
  color: var(--color-text-secondary);
}

.content-html pre {
  margin: 24rpx 0;
  padding: 24rpx;
  overflow-x: auto;
  border-radius: 20rpx;
  background: #1f2937;
  color: #f8fafc;
}

.action-bar {
  display: flex;
  padding: 18rpx;
}

.action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 24rpx;
  background: var(--color-bg-soft);
}

.action-item + .action-item {
  margin-left: 16rpx;
}

.action-icon {
  width: 38rpx;
  height: 38rpx;
  margin-right: 12rpx;
}

.action-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.author-action-bar {
  display: flex;
  align-items: center;
  padding: 12rpx;
}

.author-action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border-radius: 24rpx;
}

.author-action-icon {
  font-size: 30rpx;
}

.author-action-text {
  margin-left: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.author-action-divider {
  width: 1rpx;
  height: 44rpx;
  background: var(--color-border);
}

.author-action-item.delete .author-action-text {
  color: var(--color-brand);
}

.comment-section {
  padding: 32rpx;
}

.comment-head {
  margin-bottom: 8rpx;
}

.comment-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.comment-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comment-item {
  display: flex;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #eef1f6;
}

.comment-content {
  flex: 1;
  margin-left: 18rpx;
}

.comment-nickname {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.comment-text {
  margin-top: 12rpx;
  font-size: 29rpx;
  line-height: 1.7;
  color: var(--color-text-primary);
}

.comment-meta {
  margin-top: 12rpx;
}

.comment-time {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.no-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0 32rpx;
}

.no-comments-image {
  width: 168rpx;
  height: 126rpx;
  margin-bottom: 24rpx;
}

.no-comments-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.no-comments-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comment-compose {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx 28rpx;
  background: rgba(246, 247, 251, 0.98);
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.comment-input {
  display: flex;
  align-items: center;
  padding: 10rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: var(--shadow-md);
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 26rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.submit-btn {
  width: 132rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: var(--color-brand);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}
