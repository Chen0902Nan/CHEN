/* pages/me/me.wxss */
page {
  height: 100vh;
}

.container {
  height: 100vh;
  overflow-y: auto;
  padding: 24rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #fff2f2 0%, #f6f7fb 280rpx);
}

.user-profile {
  padding: 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #ff7677 0%, #f04142 82%);
  box-shadow: var(--shadow-brand);
}

.hero-top {
  display: flex;
  align-items: flex-start;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.username {
  font-size: 44rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #ffffff;
}

.edit-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  padding: 0 20rpx;
  margin-left: 16rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
}

.profile-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
}

.profile-avatar {
  width: 144rpx;
  height: 144rpx;
  margin-left: 24rpx;
  padding: 6rpx;
  border-radius: 72rpx;
  background: rgba(255, 255, 255, 0.18);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #ffffff;
}

.stats-row {
  display: flex;
  margin-top: 32rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.14);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 132rpx;
  border-radius: 24rpx;
  text-align: center;
}

.stat-item.active {
  background: rgba(255, 255, 255, 0.18);
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.stat-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.68);
}

.quick-actions {
  display: flex;
  margin-top: 24rpx;
}

.quick-action {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.quick-action + .quick-action {
  margin-left: 16rpx;
}

.quick-action.primary {
  background: #ffffff;
  color: var(--color-brand);
}

.stat-panel {
  margin-top: 24rpx;
  padding: 28rpx;
}

.stat-panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.stat-panel-copy {
  flex: 1;
  min-width: 0;
}

.stat-panel-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.stat-panel-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-panel-close {
  flex-shrink: 0;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: var(--color-brand-soft);
  color: var(--color-brand);
  font-size: 24rpx;
  font-weight: 600;
}

.stat-panel-loading {
  padding: 32rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.stat-user-item,
.stat-news-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.stat-user-item:last-child,
.stat-news-item:last-child {
  border-bottom: none;
}

.stat-user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #eef1f6;
}

.stat-user-main,
.stat-news-main {
  flex: 1;
  min-width: 0;
}

.stat-user-main {
  margin-left: 18rpx;
}

.stat-user-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.stat-user-account,
.stat-user-time,
.stat-news-time,
.stat-news-metric {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.relation-action {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  margin-left: 18rpx;
  border-radius: 30rpx;
  background: var(--color-brand);
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 18rpx rgba(240, 65, 66, 0.16);
}

.relation-action.active {
  background: var(--color-brand-soft);
  color: var(--color-brand);
  box-shadow: none;
}

.relation-action.disabled {
  opacity: 0.6;
}

.stat-news-title {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 600;
  color: var(--color-text-primary);
}

.stat-news-meta {
  margin-top: 12rpx;
}

.stat-news-image {
  width: 160rpx;
  height: 120rpx;
  margin-left: 18rpx;
  border-radius: 20rpx;
  background: #eef1f6;
}

.tabs-section {
  margin-top: 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: var(--color-surface);
  box-shadow: var(--shadow-sm);
}

.tabs-header {
  display: flex;
  position: relative;
  height: 92rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
  background: #ffffff;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.tab-item.active {
  color: var(--color-text-primary);
  font-weight: 700;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 33.333333%;
  height: 6rpx;
  transition: transform 0.3s ease;
}

.tab-line.tab-0 {
  transform: translateX(0);
}

.tab-line.tab-1 {
  transform: translateX(100%);
}

.tab-line.tab-2 {
  transform: translateX(200%);
}

.tab-line::after {
  content: '';
  display: block;
  width: 56rpx;
  height: 100%;
  margin: 0 auto;
  border-radius: 3rpx;
  background: var(--color-brand);
}

.tab-content {
  padding: 28rpx;
  min-height: 420rpx;
  background: #fbfcff;
}

.news-item {
  display: flex;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.news-info {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.news-title {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 32rpx;
  line-height: 1.5;
  font-weight: 600;
  color: var(--color-text-primary);
}

.news-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.news-views {
  margin-left: 16rpx;
}

.work-actions {
  display: flex;
  margin-top: 20rpx;
}

.work-action {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 22rpx;
  margin-right: 14rpx;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.work-action.edit {
  color: var(--color-brand);
  background: var(--color-brand-soft);
}

.work-action.delete {
  color: var(--color-text-secondary);
  background: #f3f5f9;
}

.news-thumb {
  width: 188rpx;
  height: 140rpx;
  border-radius: 24rpx;
  background: #eef1f6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.empty-state.compact {
  padding: 76rpx 32rpx;
}

.empty-image {
  width: 144rpx;
  height: 144rpx;
  margin-bottom: 24rpx;
}

.compact-image {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.empty-tip {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
  color: var(--color-text-secondary);
}

.action-btn.primary {
  width: 260rpx;
  height: 84rpx;
  line-height: 84rpx;
  margin-top: 28rpx;
  border-radius: 42rpx;
  background: var(--color-brand);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}
