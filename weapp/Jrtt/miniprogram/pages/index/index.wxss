.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #fff2f2 0%, #f6f7fb 260rpx);
}

.header {
  padding: 24rpx 24rpx 0;
}

.hero-card {
  padding: 28rpx;
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, #ff7a7a 0%, #f04142 78%);
  box-shadow: var(--shadow-brand);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-copy {
  margin-top: 18rpx;
}

.hero-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #ffffff;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.nav-scroll {
  margin-top: 20rpx;
  height: 72rpx;
}

.nav-list {
  display: flex;
  align-items: center;
  padding-right: 24rpx;
}

.nav-item {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  color: var(--color-text-secondary);
  font-size: 27rpx;
  white-space: nowrap;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.04);
}

.nav-item.active {
  background: var(--color-brand);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 12rpx 24rpx rgba(240, 65, 66, 0.24);
}

.news-list {
  flex: 1;
}

.news-list-inner {
  padding: 24rpx;
}

.news-item {
  display: flex;
  align-items: stretch;
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.news-item:active {
  transform: scale(0.99);
}

.news-content {
  flex: 1;
  min-width: 0;
}

.news-topline {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.news-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 21rpx;
  background: var(--color-brand-soft);
  color: var(--color-brand);
  font-size: 22rpx;
  font-weight: 600;
}

.news-time {
  margin-left: 14rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.news-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-info {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.news-dot {
  margin: 0 12rpx;
  color: var(--color-text-tertiary);
}

.news-image {
  width: 208rpx;
  height: 156rpx;
  margin-left: 24rpx;
  border-radius: 24rpx;
  background: #eef1f6;
}

.news-type {
  color: var(--color-text-tertiary);
}
