/* 新闻发布页样式 */
.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: linear-gradient(180deg, #fff2f2 0%, #f6f7fb 260rpx);
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, #ffffff 0%, #fff4f4 100%);
  border: 1rpx solid rgba(240, 65, 66, 0.12);
  box-shadow: var(--shadow-sm);
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.form-card {
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.form-group {
  margin-bottom: 36rpx;
}

.form-group.no-gap {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.helper {
  display: block;
  margin-top: 10rpx;
  margin-bottom: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.input,
.picker {
  width: 100%;
  min-height: 100rpx;
  padding: 0 30rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  background: #fbfcfe;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.arrow-text {
  font-size: 36rpx;
  color: var(--color-text-tertiary);
}

.editor-wrapper {
  padding: 20rpx;
  border-radius: 28rpx;
  background: #fbfcfe;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
}

.toolbar {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.toolbar-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin-right: 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.toolbar-btn:active {
  transform: scale(0.96);
}

.toolbar-btn.danger {
  background: var(--color-brand-soft);
}

.toolbar-icon {
  font-size: 34rpx;
}

.editor {
  width: 100%;
  height: 620rpx;
  padding: 20rpx 10rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.char-count {
  display: block;
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.image-upload {
  overflow: hidden;
  border-radius: 28rpx;
  border: 1rpx dashed rgba(240, 65, 66, 0.28);
  background: #fff8f8;
}

.upload-btn {
  height: 260rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 84rpx;
  height: 84rpx;
  margin-bottom: 18rpx;
  opacity: 0.55;
}

.upload-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.image-preview {
  position: relative;
  height: 260rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: rgba(15, 23, 42, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 32rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #ff6a6b 0%, #f04142 80%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: var(--shadow-brand);
}

.submit-btn[disabled] {
  background: #c8ced8;
  box-shadow: none;
}
