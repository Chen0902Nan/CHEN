/** app.wxss **/
page {
  --color-bg: #f6f7fb;
  --color-bg-soft: #fff7f7;
  --color-surface: #ffffff;
  --color-surface-soft: #fff2f0;
  --color-text-primary: #1b2230;
  --color-text-secondary: #6d7788;
  --color-text-tertiary: #9aa3b2;
  --color-brand: #f04142;
  --color-brand-strong: #d93032;
  --color-brand-soft: #fff1f0;
  --color-success: #07c160;
  --color-border: rgba(15, 23, 42, 0.08);

  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;

  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;

  --shadow-sm: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
  --shadow-md: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
  --shadow-brand: 0 18rpx 42rpx rgba(240, 65, 66, 0.22);

  background: var(--color-bg);
  color: var(--color-text-primary);
}

view,
scroll-view,
swiper,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

.container {
  box-sizing: border-box;
}

button {
  background: transparent;
  padding: 0;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  background: var(--color-bg);
}

.section-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.section-kicker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  background: var(--color-brand-soft);
  color: var(--color-brand);
  font-size: 22rpx;
  font-weight: 600;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.page-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.status-card {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 104rpx;
  margin-top: 24rpx;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  color: var(--color-text-secondary);
  font-size: 26rpx;
  box-shadow: var(--shadow-sm);
}

.status-card.muted {
  background: transparent;
  box-shadow: none;
  color: var(--color-text-tertiary);
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 72rpx 48rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #ffffff 0%, #fff8f8 100%);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.empty-illustration {
  width: 176rpx;
  height: 132rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
  color: var(--color-text-secondary);
}
